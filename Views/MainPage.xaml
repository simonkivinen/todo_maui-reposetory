<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todo_maui_reposetory.Views.MainPage">
    <Grid RowDefinitions="Auto,*">
        <Label 
            Text="Mina Uppgifter"
            SemanticProperties.HeadingLevel="Level1"
            FontSize="32"
            HorizontalOptions="Center" />

        <CollectionView Grid.Row="1"
                      x:Name="TaskList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Ta bort"
                                          BackgroundColor="Red"
                                          Command="{Binding Source={RelativeSource AncestorType={x:Type views:MainPage}}, Path=DeleteCommand}"
                                          CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        
                        <Grid Padding="10" ColumnDefinitions="Auto,*,Auto">
                            <CheckBox IsChecked="{Binding IsCompleted}"
                                     CheckedChanged="OnTaskCompletedChanged"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding Title}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2" 
                                   Text="{Binding DueDate, StringFormat='{0:d}'}"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button 
            Text="Lägg till uppgift"
            SemanticProperties.Hint="Lägger till en ny uppgift i listan"
            Command="{Binding AddCommand}"
            HorizontalOptions="Center" />
    </Grid>
</ContentPage>