<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todo_maui_reposetory.Views.TaskView">
    <Grid RowDefinitions="Auto,*">
        <StackLayout Orientation="Horizontal" Padding="10">
            <Label Text="{Binding CategoryTitle}" FontSize="24" VerticalOptions="Center"/>
            <Button Text="Add +" Clicked="OnAddTaskClicked" HorizontalOptions="End"/>
        </StackLayout>
        
        <CollectionView Grid.Row="1" x:Name="TaskList">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Ta bort"
                                          BackgroundColor="Red"
                                          Clicked="OnDeleteTaskSwipeClicked"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        
                        <Grid Padding="10" ColumnDefinitions="Auto,*,Auto">
                            <CheckBox IsChecked="{Binding IsCompleted}"
                                     CheckedChanged="OnTaskCompletedChanged"/>
                            <Label Grid.Column="1" 
                                   Text="{Binding Title}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2" 
                                   Text="{Binding DueDate, StringFormat='{0:d}'}"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>